# =============================================================================
# Avanzo Dashboard - Backend Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# CORS — add your frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Database — Neon Postgres (ap-southeast-1, Singapore)
# Get the connection string from the team lead / Neon console
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require
CONN_MAX_AGE=0

# Redis (only needed for Celery background tasks — optional for local dev)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/2
